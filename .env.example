# ============================================================
# SoftwareFactory Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================

# -- OpenClaw Gateway ------------------------------------------
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# -- AI Provider API Keys (at least one required) -------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# -- GitHub Integration (required for PR workflows) -----------
# Generate at: https://github.com/settings/tokens
# Scopes needed: repo, read:org
GH_TOKEN=your_github_personal_access_token_here

# -- Git Configuration ----------------------------------------
GIT_USER_NAME=SoftwareFactory Bot
GIT_USER_EMAIL=bot@yourcompany.com

# -- External Port ---------------------------------------------
SF_EXTERNAL_PORT=47391
# SF_EXTERNAL_TLS_PORT=47392

# -- Optional: Messaging Channels ------------------------------
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# SLACK_BOT_TOKEN=your_slack_bot_token_here
